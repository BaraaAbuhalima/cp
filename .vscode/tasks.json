{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: g++.exe build active file",
      "command": "C:/MinGW/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${workspaceFolder}\\output\\${fileBasenameNoExtension}.exe",
        "-std=c++23"
      ],
      "options": {
        "cwd": "C:/MinGW/bin"
      },
      "problemMatcher": ["$gcc"],
      "group": "build",
      "detail": "compiler: C:/MinGW/bin/g++.exe"
    },
    {
      "type": "shell",
      "label": "Run output exe",
      "command": "${workspaceFolder}\\output\\${fileBasenameNoExtension}.exe",
      "dependsOn": "C/C++: g++.exe build active file",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
