@charset "utf-8";

[data-md-color-scheme=3D"cpalgo"] { --md-primary-fg-color: #7777aa; --md-pr=
imary-fg-color--light: #7777aa; --md-primary-fg-color--dark: #333371; }

[data-md-color-scheme=3D"slate"] { --md-hue: 210; --md-typeset-a-color: #c9=
73d9; }

[data-md-color-scheme=3D"slate"] img { background-color: lightgray; }

.md-sidebar--primary { order: 100; }

.metadata { list-style: none; padding: 0px; margin: 0px 0px 15px; color: rg=
b(153, 153, 153); font-size: 0.85em; }

.metadata.page-metadata .contributors-text { margin-right: 5px; }

body[dir=3D"rtl"] .metadata.page-metadata .contributors-text { margin-right=
: 0px; margin-left: 5px; }

.page-metadata .contributors { display: inline-block; list-style: none; mar=
gin: 0px !important; padding: 0px !important; }

.page-metadata .contributors li { display: inline-block; vertical-align: to=
p; margin: 0px; padding: 0px; }

.mjx-copytext { font-size: 0px; }

.arithmatex { overflow-y: hidden !important; }

#donation-banner { margin: 0.75rem 0.75rem 0px; }

.donation-banner { display: flex; background: rgb(255, 249, 196); border: 1=
px solid rgb(240, 230, 140); color: rgb(43, 43, 43); padding: 0.5rem; borde=
r-radius: 8px; font-size: 0.75rem; }

.donation-text { margin: 0px; }

.donation-link { color: revert; text-decoration: underline; }

.donation-close { margin-left: auto; font-size: 1rem; cursor: pointer; }

[data-md-color-scheme=3D"slate"] .donation-banner { background: rgb(59, 50,=
 0); border-color: rgb(102, 92, 30); color: rgb(255, 247, 179); }
